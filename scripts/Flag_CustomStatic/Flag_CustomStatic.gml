function Flag_CustomStatic(){
	with(Flag_GetStorage(FLAG_STATIC)){
		Set("player_plane","plane_assault_a");
		Set("player_wingman_left","wingman_shotcannon_a");
		Set("player_wingman_right","wingman_shotcannon_a");
		Set("player_subweapon","subweapon_missile_a");
		Set("player_armor","armor_alloy_a");
		Set("current_boss_wave","wave_boss_red_heavy");
	}
}